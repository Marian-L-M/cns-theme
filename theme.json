{
  "version": 3,
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    },
    { "name": "sidebar", "title": "Sidebar", "area": "uncategorized" },
    {
      "name": "sidebar-right",
      "title": "Sidebar Right",
      "area": "uncategorized"
    }
  ],
  "customTemplates": [
    {
      "name": "wiki",
      "title": "Wiki Single Template",
      "postTypes": ["wiki"]
    }
  ],
  "settings": {
    "useRootPaddingAwareAlignments": true,
    "appearanceTools": true,
    "layout": {
      "contentSize": "92%",
      "wideSize": "1600px"
    },
    "typography": {
      "fontFamilies": [],
      "fontStyle": false,
      "fontWeight": false,
      "letterSpacing": false,
      "textDecoration": false,
      "lineHeight": false,
      "textTransform": false,
      "dropCap": false,
      "customFontSize": false,
      "fontSizes": []
    },
    "blocks": {
      "core/button": {
        "border": {
          "color": false,
          "radius": false,
          "style": false,
          "width": false
        }
      }
    },
    "color": {
      "background": true,
      "text": false,
      "link": false,
      "custom": false,
      "defaultPalette": false,
      "duotone": [],
      "customDuotone": false,
      "gradients": [],
      "customGradient": false,
      "palette": [
        {
          "slug": "primary",
          "color": "#0d3b66",
          "name": "Primary"
        },
        {
          "slug": "secondary",
          "color": "#ee964b",
          "name": "Secondary"
        },
        {
          "slug": "background",
          "color": "#f3f3f3",
          "name": "Background"
        },
        {
          "slug": "foreground",
          "color": "#333333",
          "name": "Foreground"
        },
        {
          "slug": "header-bg",
          "color": "#23282d;",
          "name": "Header-Bg"
        },
        {
          "slug": "header-text",
          "color": "#FFFFFF",
          "name": "Header-Text"
        }
      ]
    }
  },
  "styles": {
    "blocks": {
      "core/button": {
        "color": {
          "text": "#FFFFFF",
          "background": "var(--wp--preset--color--primary)"
        }
      }
    },
    "spacing": {
      "blockGap": "0",
      "padding": {
        "left": "var(--wp--preset--spacing--50, 1rem)",
        "right": "var(--wp--preset--spacing--50, 1rem)"
      }
    }
  }
}
