{
  "name": "clouds-and-spaceships-template",
  "version": "1.0.0",
  "description": "A wordpress template for the clouds and spaceships map making system",
  "homepage": "https://cloudsandspaceships.com/",
  "bugs": {
    "url": "https://github.com/Marian-L-M/cns-theme/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Marian-L-M/cns-theme.git"
  },
  "license": "ISC",
  "author": "Marian Maschke",
  "main": "index.js",
  "scripts": {
    "start": "wp-scripts start --experimental-modules",
    "blocks": "wp-scripts start --experimental-modules",
    "build": "npm run buildIndex && npm run buildBlocks",
    "buildIndex": "wp-scripts build --config webpack.index.config.js",
    "watchIndex": "wp-scripts start --config webpack.index.config.js",
    "buildBlocks": "wp-scripts build --experimental-modules",
    "dev": "wp-scripts start",
    "devFast": "wp-scripts start",
    "test": "echo \\\"Error: no test specified\\\" && exit 1"
  },
  "devDependencies": {
    "@prettier/plugin-php": "^0.24.0",
    "concurrently": "^9.2.1",
    "fast-glob": "^3.3.3",
    "prettier": "^3.6.2",
    "sass": "^1.97.3"
  },
  "dependencies": {
    "@glidejs/glide": "^3.7.1",
    "@wordpress/icons": "^11.6.0",
    "@wordpress/scripts": "^31.1.0",
    "axios": "^1.13.2"
  }
}
