{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "cns-theme/cns-header-nav",
  "version": "0.1.0",
  "title": "CNS Header Navigation",
  "category": "design",
  "icon": "widgets-menus",
  "description": "Navigation Block for the CNS theme header",
  "example": {},
  "supports": {
    "html": false,
    "align": ["left", "center", "right"]
  },
  "attributes": {
    "mode": {
      "type": "string",
      "default": "side-nav"
    },
    "items": {
      "type": "array",
      "default": []
    }
  },
  "textdomain": "cns-theme",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}
